# تابع دریافت پروفایل کاربر از تحلیل
# ============================================
def get_user_analysis():
    """دریافت اطلاعات از آخرین تحلیل"""
    if st.session_state.history:
        last = st.session_state.history[-1]

        # تبدیل نام فارسی به انگلیسی
        shape_map = {
            "⌛ ساعت شنی": "Hourglass",
            "🍐 گلابی": "Pear",
            "🍎 سیب": "Apple",
            "🔻 مثلث معکوس": "Inverted Triangle",
            "📏 مستطیل": "Rectangle"
        }

        return {
            'body_shape_fa': last.get('shape', None),
            'body_shape': shape_map.get(last.get('shape', '')),
            'skin_tone': last.get('skin', None),
            'undertone': last.get('undertone', None),
            'gender': last.get('gender', None),
            'confidence': last.get('confidence', None)
        }
    return None


# ============================================
# تابع نمایش Confidence Score
# ============================================
def show_confidence_scores(current_shape, gender):
    """نمایش درصد اطمینان برای هر نوع اندام"""

    shapes = list(BODY_SHAPES[gender].keys())
    scores = []

    for shape in shapes:
        if shape == current_shape:
            scores.append(82.0)  # امتیاز برای تشخیص فعلی
        elif shape in ['Hourglass', 'Rectangle'] and current_shape in ['Hourglass', 'Rectangle']:
            scores.append(35.0)  # نزدیک
        elif shape in ['Pear', 'Inverted Triangle'] and current_shape in ['Pear', 'Inverted Triangle']:
            scores.append(28.0)
        elif shape == 'Apple' and current_shape == 'Apple':
            scores.append(82.0)
        else:
            scores.append(12.0)  # دور

    # نرمال‌سازی
    total = sum(scores)
    percentages = [s / total * 100 for s in scores]

    return shapes, percentages


